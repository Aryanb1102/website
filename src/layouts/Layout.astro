---
import '../styles/global.css';
import Navbar from '../components/react/Navbar';
import Footer from '../components/Footer.astro';

const { title = 'Cybersecurity Portfolio', description = 'Computer Science student specializing in cybersecurity, network infrastructure, and data privacy.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen">
    <Navbar client:load />
    <main class="pt-24">
      <slot />
    </main>
    <Footer />
  </body>
</html>
