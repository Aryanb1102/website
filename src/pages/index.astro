---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/react/HeroSection';
import ProjectCard from '../components/react/ProjectCard';
import Reveal from '../components/react/Reveal';
import FeaturedProjectCarousel from '../components/react/FeaturedProjectCarousel';

const base = import.meta.env.BASE_URL;

const projects = [
  {
    title: 'Censorship Detector (India)',
    description:
      'Network-level measurement system detecting DNS tampering, HTTP interference, and regional filtering patterns using distributed probes and anomaly correlation.',
    tags: ['Network Measurement', 'Censorship', 'DNS/HTTP/TLS', 'Python', 'Policy'],
    href: '/projects/censorship-detector-india',
  },
  {
    title: 'GRC Automation Tool',
    description:
      'Automated compliance workflow mapping security controls to ISO 27001/SOC 2 requirements with risk scoring, evidence tracking, and dashboard reporting.',
    tags: ['GRC', 'Compliance', 'Risk Assessment', 'Automation'],
    href: '/projects/grc-automation-tool',
  },
  {
    title: 'ML-Based DDoS Intrusion Detection System',
    description:
      'Supervised machine learning model classifying DDoS traffic using flow-level features and anomaly detection to reduce false positives in real-time network monitoring.',
    tags: ['Machine Learning', 'Intrusion Detection', 'Network Security', 'Python'],
    href: '/projects/ddos-ml-intrusion-detection',
  },
];

---

<Layout title="Aryan | Security, Systems, Policy">
  <HeroSection client:load />

  <section class="section-padding">
    <div class="mx-auto w-full max-w-container px-6">
      <Reveal client:visible>
        <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
          <p class="text-sm uppercase tracking-[0.35em] text-white/50">Security Projects</p>
          <h2 class="mt-4 font-heading text-3xl">Projects at the intersection of security and governance</h2>
          </div>
          <a href={`${base}projects/`} class="text-sm text-white/70 transition hover:text-white">
            Explore all projects →
          </a>
        </div>
      </Reveal>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {projects.map((project) => (
          <Reveal client:visible key={project.title}>
            <ProjectCard {...project} />
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="mx-auto w-full max-w-container px-6">
      <Reveal client:visible>
        <div class="glass-strong gradient-border rounded-2xl p-10 md:p-12">
          <FeaturedProjectCarousel client:load />
        </div>
      </Reveal>
    </div>
  </section>
</Layout>
