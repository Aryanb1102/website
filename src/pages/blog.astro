---
import Layout from '../layouts/Layout.astro';
import Reveal from '../components/react/Reveal';
---

<Layout title="Blog | Aryan">
  <section class="section-padding">
    <div class="mx-auto w-full max-w-container px-6">
      <Reveal client:visible>
        <div class="max-w-2xl">
          <p class="text-sm uppercase tracking-[0.35em] text-white/50">Blog</p>
          <h1 class="mt-4 font-heading text-4xl">Writing on security, systems, and the internet</h1>
          <p class="mt-4 text-white/70">
            This section remains active, but the public post listing is currently hidden.
          </p>
        </div>
      </Reveal>
    </div>
  </section>
</Layout>
