---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/react/ProjectCard';
import Reveal from '../components/react/Reveal';

const projects = [
  {
    title: 'Censorship Detector (India)',
    description:
      'Network-level measurement system detecting DNS tampering, HTTP interference, and regional filtering patterns using distributed probes and anomaly correlation.',
    tags: ['Network Measurement', 'Censorship', 'DNS/HTTP/TLS', 'Python', 'Policy'],
    href: '/projects/censorship-detector-india',
  },
  {
    title: 'Airflow-Based GRC Automation Pipeline',
    description:
      'Automated compliance workflow mapping security controls to ISO 27001/SOC 2 requirements with risk scoring, evidence tracking, and dashboard reporting.',
    tags: ['GRC', 'Compliance', 'Risk Assessment', 'Automation'],
    href: '/projects/grc-automation-tool',
  },
  {
    title: 'ML-Based DDoS Intrusion Detection System',
    description:
      'Supervised machine learning model classifying DDoS traffic using flow-level features and anomaly detection to reduce false positives in real-time network monitoring.',
    tags: ['Machine Learning', 'Intrusion Detection', 'Network Security', 'Python'],
    href: '/projects/ddos-ml-intrusion-detection',
  },
  {
    title: 'Cluless Context-Aware Digital Closet',
    description:
      'Mobile-first wardrobe assistant that generates outfit recommendations using weather context and user feedback to reduce daily decision fatigue.',
    tags: ['Product', 'Mobile', 'Recommendation', 'UX'],
    href: '/projects/cluless-context-aware-digital-closet',
  },
];
---

<Layout title="Projects | Aryan">
  <section class="section-padding">
    <div class="mx-auto w-full max-w-container px-6">
      <Reveal client:visible>
        <div class="max-w-2xl">
          <p class="text-sm uppercase tracking-[0.35em] text-white/50">Projects</p>
          <h1 class="mt-4 font-heading text-4xl">Security and infrastructure research in motion</h1>
          <p class="mt-4 text-white/70">
            These projects combine technical depth with real-world context, spanning privacy automation, network
            measurement, systems tooling, and applied ML. The emphasis is on trust, availability, and practical impact
            for both engineering and product decisions.
          </p>
        </div>
      </Reveal>
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {projects.map((project) => (
          <Reveal client:visible key={project.title}>
            <ProjectCard {...project} />
          </Reveal>
        ))}
      </div>
    </div>
  </section>
</Layout>
