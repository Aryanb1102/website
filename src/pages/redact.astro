---
import Layout from '../layouts/Layout.astro';
import Reveal from '../components/react/Reveal';
---

<Layout title="Redact | Asha Patel">
  <section class="section-padding">
    <div class="mx-auto w-full max-w-container px-6">
      <Reveal client:visible>
        <div class="max-w-2xl">
          <p class="text-sm uppercase tracking-[0.35em] text-white/50">Redact</p>
          <h1 class="mt-4 font-heading text-4xl">Redact: privacy automation and auditable workflows</h1>
          <p class="mt-4 text-white/70">
            Redact is a privacy automation project that helps users reduce their digital footprint by automating
            data-broker opt-outs, search cleanup, and account deletion. It is centered on Indian privacy (DPDPA),
            privacy-by-design principles, and auditable, user-first workflows.
          </p>
        </div>
      </Reveal>

      <div class="mt-12 grid gap-8 lg:grid-cols-3">
        <Reveal client:visible>
          <div class="glass gradient-border rounded-2xl p-6">
            <h2 class="font-heading text-xl">Privacy Automation</h2>
            <p class="mt-3 text-sm text-white/70">
              Automating opt-outs, search cleanup, and account deletion with clear user control and evidence trails.
            </p>
          </div>
        </Reveal>
        <Reveal client:visible>
          <div class="glass gradient-border rounded-2xl p-6">
            <h2 class="font-heading text-xl">DPDPA-Aligned Workflows</h2>
            <p class="mt-3 text-sm text-white/70">
              Building consent-aware processes that reflect Indian privacy requirements and real operational needs.
            </p>
          </div>
        </Reveal>
        <Reveal client:visible>
          <div class="glass gradient-border rounded-2xl p-6">
            <h2 class="font-heading text-xl">Auditable by Design</h2>
            <p class="mt-3 text-sm text-white/70">
              Emphasis on verifiable actions, clear logs, and user-readable summaries of what changed and why.
            </p>
          </div>
        </Reveal>
      </div>

      <Reveal client:visible>
        <div class="mt-12 glass-strong rounded-2xl p-8">
          <h2 class="font-heading text-2xl">Core questions guiding the work</h2>
          <ul class="mt-4 space-y-3 text-sm text-white/70">
            <li>How do we automate privacy actions without weakening user trust?</li>
            <li>What does DPDPA compliance look like in real user workflows?</li>
            <li>How can audit trails remain clear without exposing personal data?</li>
          </ul>
        </div>
      </Reveal>
    </div>
  </section>
</Layout>
